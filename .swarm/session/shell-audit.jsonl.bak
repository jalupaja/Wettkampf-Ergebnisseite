er;\n    margin-bottom: 28px;\n  }\n  \n  .logo-icon {\n    width: 64px;\n    height: 64px;\n    background: var(--color-primary);\n    color: white;\n    font-size: 32px;\n    font-weight: bold;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin: 0 auto 14px;\n  }\n  \n  .logo h1 {\n    font-size: 24px;\n    margin-bottom: 4px;\n  }\n  \n  .logo p {\n    color: var(--color-text-muted);\n    font-size: 13px;\n  }\n  \n  form {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n  \n  .error-message {\n    background: rgba(231, 76, 60, 0.1);\n    border: 1px solid var(--color-error);\n    color: var(--color-error);\n    padding: 12px;\n    border-radius: 8px;\n    font-size: 14px;\n    margin-bottom: 16px;\n  }\n  \n  .form-group {\n    margin-bottom: 16px;\n  }\n  \n  .form-group label {\n    display: block;\n    margin-bottom: 6px;\n    font-weight: 500;\n  }\n  \n  button {\n    width: 100%;\n    margin-top: 8px;\n  }\n  \n  @media (max-width: 400px) {\n    .login-card {\n      padding: 24px 16px;\n    }\n    \n    .logo-icon {\n      width: 56px;\n      height: 56px;\n      font-size: 28px;\n    }\n  }\n</style>\nEOF\necho \"Login.svelte fixed\""}
